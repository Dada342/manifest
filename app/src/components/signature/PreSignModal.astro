---
// Modal that opens when clicking "Sign" button
// Shows fireworks, countdown, thank you message, share buttons
// After 5 seconds, opens GitHub sign page in new tab

const REPO = 'ai-driven-dev/manifest';
const TARGET_PATH = 'app/src/content/signatories';

const TEMPLATE = `github: your-handle
name: Your Full Name
linkedin: # optional - https://www.linkedin.com/in/...
affiliation: # optional - title or company
statement: # optional - one-line public statement (max 280 chars)
`;

const GITHUB_HREF = `https://github.com/${REPO}/new/main/${TARGET_PATH}?filename=YOUR-HANDLE.yml&value=${encodeURIComponent(TEMPLATE)}`;
---

<dialog id="presign-dialog" class="presign-dialog" aria-labelledby="presign-title">
  <div class="presign-card">
    <div class="presign-fireworks" id="fireworks-container"></div>
    <div class="presign-content">
      <h2 id="presign-title" class="presign-title">Thank you!</h2>
      <p class="presign-message" id="presign-message">
        Redirecting to GitHub in <span id="countdown">5</span>...
      </p>
      <p class="presign-submessage">Share your support now:</p>
      <div class="presign-share-actions">
        <a class="presign-share-btn" id="presign-linkedin" href="" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path fill="currentColor" d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.13 1 2.5 1s2.48 1.12 2.48 2.5zM.22 8h4.56v14H.22V8zm7.66 0h4.37v1.92h.06c.61-1.16 2.1-2.38 4.32-2.38 4.62 0 5.47 3.04 5.47 7v8.46h-4.55v-7.5c0-1.79-.03-4.09-2.49-4.09-2.5 0-2.88 1.95-2.88 3.96V22H7.88V8z"/>
          </svg>
          <span>Share on LinkedIn</span>
        </a>
        <a class="presign-share-btn presign-share-btn--ghost" id="presign-x" href="" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path fill="currentColor" d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.657l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.451-6.231zm-1.161 17.52h1.833L7.084 4.126H5.117l11.966 15.644z"/>
          </svg>
          <span>Share on X</span>
        </a>
      </div>
    </div>
  </div>
</dialog>

<script is:inline>
  (function() {
    // Emojis for fireworks
    const emojis = ['🎆', '🎇', '🎉', '✨', '💫', '🌟', '🎊', '🎈', '🎁', '🥳', '🎌', '🎋'];
    const dialog = document.getElementById('presign-dialog');
    const countdownEl = document.getElementById('countdown');
    const fireworksContainer = document.getElementById('fireworks-container');
    const linkedInBtn = document.getElementById('presign-linkedin');
    const xBtn = document.getElementById('presign-x');
    const titleEl = document.getElementById('presign-title');
    const messageEl = document.getElementById('presign-message');
    const subMessageEl = document.querySelector('.presign-submessage');

    let countdown = 5;
    let timer: ReturnType<typeof setTimeout>;
    let redirectTimer: ReturnType<typeof setTimeout>;

    // Get browser language
    const userLang = (navigator.language || '').split('-')[0];
    const isFrench = userLang === 'fr';

    // Localized text
    if (isFrench) {
      if (titleEl) titleEl.textContent = 'Merci !';
      if (messageEl) messageEl.innerHTML = 'Redirection vers GitHub dans <span id="countdown">5</span>...';
      if (subMessageEl) subMessageEl.textContent = 'Partagez votre soutien maintenant :';
    }

    // Localized share messages with fireworks emoji
    const siteUrl = 'https://ai-driven-development.org';
    const textFr = encodeURIComponent('Je viens de signer le manifeste 🎆 ' + siteUrl);
    const textEn = encodeURIComponent('I just signed the Manifesto for AI-Driven Development 🎆 ' + siteUrl);
    const message = isFrench ? textFr : textEn;

    // Set share button hrefs
    if (linkedInBtn) {
      linkedInBtn.href = `https://www.linkedin.com/feed/?shareActive=true&text=${message}`;
    }
    if (xBtn) {
      xBtn.href = `https://x.com/intent/post?text=${message}`;
    }

    // Create fireworks
    function createFireworks() {
      if (!fireworksContainer) return;

      const burstCount = 15;
      for (let i = 0; i < burstCount; i++) {
        setTimeout(() => {
          createEmojiBurst();
        }, i * 200);
      }
    }

    function createEmojiBurst() {
      if (!fireworksContainer) return;

      const burstSize = 10 + Math.random() * 15;
      const startX = Math.random() * window.innerWidth;
      const startY = Math.random() * window.innerHeight * 0.3;

      for (let i = 0; i < burstSize; i++) {
        createFallingEmoji(startX, startY);
      }
    }

    function createFallingEmoji(startX: number, startY: number) {
      if (!fireworksContainer) return;

      const emoji = emojis[Math.floor(Math.random() * emojis.length)];
      const size = 16 + Math.random() * 32;
      const duration = 2000 + Math.random() * 3000;
      const delay = Math.random() * 500;
      const endX = startX + (Math.random() - 0.5) * 200;
      const endY = startY + 300 + Math.random() * 400;
      const rotation = Math.random() * 360;
      const spin = Math.random() > 0.5 ? 360 : -360;

      const element = document.createElement('span');
      element.className = 'falling-emoji';
      element.textContent = emoji;
      
      element.style.setProperty('--start-x', startX + 'px');
      element.style.setProperty('--start-y', startY + 'px');
      element.style.setProperty('--end-x', endX + 'px');
      element.style.setProperty('--end-y', endY + 'px');
      element.style.setProperty('--size', size + 'px');
      element.style.setProperty('--duration', duration + 'ms');
      element.style.setProperty('--delay', delay + 'ms');
      element.style.setProperty('--rotation', rotation + 'deg');
      element.style.setProperty('--spin', spin + 'deg');
      
      fireworksContainer.appendChild(element);

      setTimeout(() => {
        element.remove();
      }, duration + delay);
    }

    // Start countdown
    function startCountdown() {
      if (countdownEl) {
        countdownEl.textContent = String(countdown);
      }

      timer = setInterval(() => {
        countdown--;
        if (countdownEl) {
          countdownEl.textContent = String(countdown);
        }
        if (countdown <= 0) {
          clearInterval(timer);
          // Open GitHub
          window.open('https://github.com/ai-driven-dev/manifest/new/main/app/src/content/signatories?filename=YOUR-HANDLE.yml&value=' + encodeURIComponent(TEMPLATE), '_blank', 'noopener');
        }
      }, 1000);

      // Also open after 5 seconds as backup
      redirectTimer = setTimeout(() => {
        window.open('https://github.com/ai-driven-dev/manifest/new/main/app/src/content/signatories?filename=YOUR-HANDLE.yml&value=' + encodeURIComponent(TEMPLATE), '_blank', 'noopener');
      }, 5000);
    }

    // Open dialog and start everything
    function openModal() {
      if (!dialog) return;
      
      // Reset countdown
      countdown = 5;
      if (countdownEl) {
        countdownEl.textContent = '5';
      }

      // Clear previous timers
      if (timer) clearInterval(timer);
      if (redirectTimer) clearTimeout(redirectTimer);

      // Clear previous fireworks
      if (fireworksContainer) {
        fireworksContainer.innerHTML = '';
      }

      // Show dialog
      dialog.showModal();
      
      // Start fireworks after small delay
      setTimeout(() => {
        createFireworks();
      }, 100);

      // Start countdown
      startCountdown();
    }

    // Close dialog
    function closeModal() {
      if (dialog) {
        dialog.close();
      }
      if (timer) clearInterval(timer);
      if (redirectTimer) clearTimeout(redirectTimer);
    }

    // Expose open function to window for external triggering
    (window as any).openPreSignModal = openModal;
    (window as any).closePreSignModal = closeModal;
  })();
</script>
