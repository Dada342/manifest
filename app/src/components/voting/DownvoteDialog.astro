---
---
<dialog id="downvoteDialog" class="downvote-dialog">
  <form method="dialog" id="downvoteForm" class="dv-form" novalidate>
    <div class="dv-brand">
      <span class="dv-chip">−1</span>
      <span class="dv-kicker">Disagreement · Recorded</span>
    </div>
    <h4>Tell us what rings false.</h4>
    <p class="dv-hint">A reason and an alternative help us refine the manifesto. Your name stays out of this — only the line you suggest matters.</p>

    <input type="hidden" id="dvTargetType" />
    <input type="hidden" id="dvTargetId" />

    <label class="dv-field">
      <span>What rings false</span>
      <textarea id="dvReason" rows="3" maxlength="500" required placeholder="The principle assumes …"></textarea>
    </label>
    <label class="dv-field">
      <span>What you'd write instead</span>
      <textarea id="dvAlternative" rows="3" maxlength="500" required placeholder="It should read …"></textarea>
    </label>

    <div class="dialog-actions">
      <button type="button" class="dialog-cancel" data-close>Skip</button>
      <button type="submit" class="dv-action">Send <span class="arrow">→</span></button>
    </div>
  </form>
</dialog>
<style>
.downvote-dialog {
  border: none;
  padding: 0;
  border-radius: 14px;
  background: var(--paper);
  color: var(--ink);
  max-width: 480px;
  width: 92vw;
  box-shadow:
    0 1px 0 0 oklch(from var(--paper) calc(l + 0.04) c h) inset,
    0 30px 80px -20px oklch(0.18 0.012 60 / 0.45);
  overflow: hidden;
}
.downvote-dialog[open] { animation: dv-in .35s cubic-bezier(.2,.7,.2,1); }
.downvote-dialog[open]::backdrop { animation: dv-fade .35s ease both; }
@keyframes dv-in { from { opacity: 0; transform: translateY(12px) scale(0.97); } to { opacity: 1; transform: translateY(0) scale(1); } }
@keyframes dv-fade { from { opacity: 0 } to { opacity: 1 } }
.downvote-dialog::backdrop {
  background: oklch(0.18 0.012 60 / 0.55);
  backdrop-filter: blur(6px);
}
.dv-form {
  display: grid; gap: 14px;
  padding: 28px 28px 22px;
}
.dv-brand { display: inline-flex; align-items: center; gap: 10px; }
.dv-chip {
  display: inline-flex; align-items: center; justify-content: center;
  width: 30px; height: 22px;
  background: oklch(0.55 0.18 25 / 0.14);
  color: oklch(0.55 0.18 25);
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.04em;
  border-radius: 4px;
  font-variation-settings: "opsz" 96, "wght" 500;
}
.dv-kicker {
  font-family: var(--mono);
  font-size: 10.5px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--ink-3);
}
.downvote-dialog h4 {
  font-family: var(--serif);
  font-variation-settings: "opsz" 144, "wght" 360;
  font-style: italic;
  font-size: 28px;
  line-height: 1.05;
  margin: 4px 0 0;
  color: var(--ink);
}
.dv-hint {
  font-family: var(--sans);
  font-size: 13.5px; line-height: 1.55;
  color: var(--ink-2);
  margin: 0 0 4px;
  max-width: 42ch;
}
.dv-field { display: grid; gap: 6px; }
.dv-field > span {
  font-family: var(--mono);
  font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase;
  color: var(--ink-3);
}
.dv-field textarea {
  font-family: var(--sans);
  font-size: 14px; line-height: 1.5;
  padding: 12px 14px;
  border: 1px solid var(--rule);
  background: var(--paper-2);
  color: var(--ink);
  border-radius: 6px;
  resize: vertical;
  min-height: 72px;
  outline: none;
  transition: border-color .2s, box-shadow .2s;
}
.dv-field textarea:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px var(--accent-soft);
}
.dialog-actions { display: flex; gap: 10px; justify-content: flex-end; margin-top: 6px; }
.dialog-cancel {
  background: none;
  border: 1px solid var(--rule);
  padding: 11px 16px;
  cursor: pointer;
  font-family: var(--mono);
  font-size: 10.5px; letter-spacing: 0.18em; text-transform: uppercase;
  color: var(--ink-2);
  border-radius: 6px;
  transition: border-color .2s, color .2s;
}
.dialog-cancel:hover { border-color: var(--ink); color: var(--ink); }
.dv-action {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 11px 18px;
  border: none; cursor: pointer;
  border-radius: 6px;
  background: linear-gradient(135deg, oklch(0.55 0.18 25), oklch(0.42 0.16 25));
  color: oklch(0.97 0.01 240);
  font-family: var(--mono);
  font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase;
  box-shadow: 0 8px 24px -8px oklch(0.42 0.16 25 / 0.55);
  transition: transform .2s, filter .2s;
}
.dv-action:hover { filter: brightness(1.08); transform: translateY(-1px); }
.dv-action .arrow { transition: transform .2s; }
.dv-action:hover .arrow { transform: translateX(3px); }
</style>
